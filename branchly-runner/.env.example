ENVIRONMENT=dev
PORT=8081
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=branchly

# Global fallback API keys — used when a user has not configured their own key (BYOK).
# Both are optional if all users configure their own keys via Settings → API keys.
# If no key is available (global or user-specific), the job fails with a clear error.
ANTHROPIC_API_KEY=   # fallback for Claude Code jobs
GEMINI_API_KEY=      # fallback for Gemini CLI jobs

ENCRYPTION_KEY=0000000000000000000000000001000000000000000000000000000000000000
RUNNER_SECRET=change-me-internal-secret
INTERNAL_API_SECRET=change-me-internal-secret

MAX_CONCURRENT_JOBS=3
SHUTDOWN_TIMEOUT=8m
WORK_DIR=
